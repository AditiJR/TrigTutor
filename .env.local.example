# Copy to .env.local and fill in real values. Do not commit .env.local.

# Anthropic Claude (Socratic hint generation only — never decides correctness)
ANTHROPIC_API_KEY=

# Google Gemini (OCR via lib/geminiVision.ts + POST /api/generate-steps)
# API key from AI Studio: https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=

# Optional: force a single model id (otherwise fallback list is used on 404).
# GEMINI_MODEL=gemini-2.0-flash-001

# Optional comma-separated list (used if GEMINI_MODEL is unset).
# GEMINI_MODEL_FALLBACK_LIST=gemini-2.0-flash-001,gemini-2.5-flash,gemini-flash-latest

# Python SymPy sidecar
PYTHON_SERVICE_URL=http://localhost:8000
PYTHON_SERVICE_TOKEN=dev-shared-secret-change-me
